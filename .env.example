# ============================================================
# openkhang — Digital Twin Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ============================================================

# --- Agent Replies (Meridian default, Claude API fallback) ---
# Meridian: run `meridian` locally, uses Claude Max subscription quota ($0 marginal)
MERIDIAN_URL=http://127.0.0.1:3456
ANTHROPIC_API_KEY=sk-ant-...

# --- Mem0 Memory Extraction (Gemini free tier) ---
GEMINI_API_KEY=

# --- Jira (jira-cli) ---
JIRA_SERVER=https://your-jira.example.com
JIRA_AUTH_TYPE=bearer
JIRA_API_TOKEN=
JIRA_PROJECT=YOUR_PROJECT

# --- Confluence (atlassian-cli) ---
CONFLUENCE_DOMAIN=your-confluence.example.com
CONFLUENCE_API_PATH=/rest/api
CONFLUENCE_AUTH_TYPE=basic
CONFLUENCE_API_TOKEN=
CONFLUENCE_USERNAME=your.username

# --- GitLab (glab) ---
GITLAB_HOST=https://gitlab.example.com
GITLAB_TOKEN=
# Comma-separated GitLab projects to poll MRs from
GITLAB_PROJECTS=group/project1,group/project2

# --- Google Chat (via mautrix-googlechat bridge) ---
# Setup: bash scripts/setup-bridge.sh
MATRIX_HOMESERVER=http://localhost:8008
MATRIX_ACCESS_TOKEN=
MATRIX_USER=@claude:localhost

# --- openkhang Memory Layer (auto-configured by setup-memory.sh) ---
OPENKHANG_DATABASE_URL=postgresql://openkhang:openkhang@localhost:5433/openkhang
OPENKHANG_REDIS_URL=redis://localhost:6379
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# --- Telegram Bot (optional — push notifications + inward chat) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=  # empty = polling mode for local dev
